generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  name          String          @default("")
  id            String          @id @default(uuid())
  username      String          @unique
  email         String          @unique
  activated     Boolean         @default(true)
  password      String
  role          userRole        @default(USER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  userImg       String          @default("")
  isDeleted     Boolean         @default(false)
  deletedAt     DateTime?
  ClaimAuditLog ClaimAuditLog[]
  claim         Claim[]
  foundItem     FoundItem[]
  LostItem      LostItem[]
  Comment       Comment[]
  UserReputation UserReputation?
  DiscussionThread DiscussionThread[]
  ThreadReply    ThreadReply[]
  ReputationHistory ReputationHistory[]
  UserBadge      UserBadge[]
  AnalyticsExport AnalyticsExport[]
  ModerationAction ModerationAction[]

  @@map("users")
}

model ItemCategory {
  id         String      @id @default(uuid())
  name       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  foundItems FoundItem[]
  LostItem   LostItem[]

  @@map("itemsCategories")
}

model FoundItem {
  id                 String              @id @default(uuid())
  userId             String?
  img                String              @default("")
  categoryId         String
  foundItemName      String
  description        String
  location           String
  date               DateTime            @default(now())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  claimProcess       String              @default("")
  isClaimed          Boolean             @default(false)
  isDeleted          Boolean             @default(false)
  deletedAt          DateTime?
  reporterName       String              @default("")
  archivedAt         DateTime?
  isArchived         Boolean             @default(false)
  schoolEmail        String              @default("")
  claim              Claim[]
  category           ItemCategory        @relation(fields: [categoryId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  matchNotifications MatchNotification[]
  Comment            Comment[]

  @@map("foundItems")
}

model LostItem {
  id                 String              @id @default(uuid())
  userId             String?
  lostItemName       String
  categoryId         String
  img                String              @default("")
  description        String
  location           String
  date               DateTime
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isFound            Boolean             @default(false)
  isDeleted          Boolean             @default(false)
  deletedAt          DateTime?
  reporterName       String              @default("")
  schoolEmail        String              @default("")
  category           ItemCategory        @relation(fields: [categoryId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  matchNotifications MatchNotification[]
  Comment            Comment[]

  @@map("lostItems")
}

model Claim {
  id                     String          @id @default(uuid())
  userId                 String?
  foundItemId            String
  isDeleted              Boolean         @default(false)
  deletedAt              DateTime?
  status                 status          @default(PENDING)
  distinguishingFeatures String?
  lostDate               DateTime
  claimantName           String          @default("")
  contactNumber          String          @default("")
  schoolEmail            String          @default("")
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  auditLogs              ClaimAuditLog[]
  foundItem              FoundItem       @relation(fields: [foundItemId], references: [id])
  user                   User?           @relation(fields: [userId], references: [id])

  @@map("claims")
}

model ClaimAuditLog {
  id              String   @id @default(uuid())
  claimId         String
  action          String
  fromStatus      String
  toStatus        String
  performedBy     String   @default("Admin")
  performedById   String?
  note            String   @default("")
  createdAt       DateTime @default(now())
  claim           Claim    @relation(fields: [claimId], references: [id])
  performedByUser User?    @relation(fields: [performedById], references: [id])

  @@map("claimAuditLogs")
}

model BulletinPost {
  id           String        @id @default(uuid())
  itemName     String
  description  String
  location     String
  dateLost     DateTime
  imageUrl     String        @default("")
  reporterName String        @default("")
  contactHint  String        @default("")
  isResolved   Boolean       @default(false)
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tips         BulletinTip[]

  @@map("bulletinPosts")
}

model BulletinTip {
  id             String       @id @default(uuid())
  bulletinPostId String
  location       String       @default("")
  details        String
  createdAt      DateTime     @default(now())
  bulletinPost   BulletinPost @relation(fields: [bulletinPostId], references: [id])

  @@map("bulletinTips")
}

model MatchNotification {
  id          String    @id @default(uuid())
  lostItemId  String
  foundItemId String
  sentAt      DateTime  @default(now())
  foundItem   FoundItem @relation(fields: [foundItemId], references: [id])
  lostItem    LostItem  @relation(fields: [lostItemId], references: [id])

  @@unique([lostItemId, foundItemId])
  @@map("matchNotifications")
}

model Student {
  id         String   @id
  name       String
  email      String   @unique
  department String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("students")
}

model Comment {
  id            String        @id @default(uuid())
  itemId        String
  itemType      ItemType
  userId        String?       // null for anonymous
  content       String
  isAnonymous   Boolean       @default(false)
  helpfulCount  Int           @default(0)
  status        CommentStatus @default(PENDING)
  location      String?
  time          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  foundItem     FoundItem?    @relation(fields: [itemId], references: [id], map: "comments_foundItem_fkey")
  lostItem      LostItem?     @relation(fields: [itemId], references: [id], map: "comments_lostItem_fkey")
  user          User?         @relation(fields: [userId], references: [id])
  
  @@map("comments")
}

model DiscussionThread {
  id          String           @id @default(uuid())
  title       String
  category    ThreadCategory
  createdBy   String
  isPinned    Boolean          @default(false)
  replyCount  Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  creator     User             @relation(fields: [createdBy], references: [id])
  replies     ThreadReply[]
  
  @@map("discussion_threads")
}

model ThreadReply {
  id           String   @id @default(uuid())
  threadId     String
  userId       String
  content      String
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  
  thread       DiscussionThread @relation(fields: [threadId], references: [id])
  user         User             @relation(fields: [userId], references: [id])
  
  @@map("thread_replies")
}

model UserReputation {
  userId              String     @id
  helpfulPoints       Int        @default(0)
  commentsCount       Int        @default(0)
  verifiedSightings   Int        @default(0)
  threadsCreated      Int        @default(0)
  reputationPoints    Int        @default(0)
  trustLevel          TrustLevel @default(NEW)
  lastCalculated      DateTime   @default(now())
  
  user                User       @relation(fields: [userId], references: [id])
  
  @@map("user_reputation")
}

model ReputationHistory {
  id            String   @id @default(uuid())
  userId        String
  actionType    String
  pointsChange  Int
  reason        String
  referenceId   String?
  createdAt     DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id])

  @@map("reputation_history")
}

model BadgeDefinition {
  id            String      @id @default(uuid())
  name          String
  description   String
  icon          String
  unlockPoints  Int
  category      String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  userBadges    UserBadge[]

  @@map("badge_definitions")
}

model UserBadge {
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  badgeData Json?
  
  user      User            @relation(fields: [userId], references: [id])
  badge     BadgeDefinition @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
  @@map("user_badges")
}

model AnalyticsMetric {
  id          String   @id @default(uuid())
  name        String   @unique
  value       Float
  category    String
  recordedAt  DateTime @default(now())

  @@map("analytics_metrics")
}

model AnalyticsExport {
  id           String    @id @default(uuid())
  exportName   String
  exportType   String
  exportFormat String
  dateRange    String
  createdBy    String
  exportStatus String    @default("pending") // pending, processing, completed, failed
  filePath     String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  
  user         User      @relation(fields: [createdBy], references: [id])

  @@map("analytics_exports")
}

model AnalyticsAlert {
  id             String   @id @default(uuid())
  alertName      String
  alertType      String
  thresholdValue Float
  metricName     String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("analytics_alerts")
}

model ModerationAction {
  id           String   @id @default(uuid())
  moderatorId  String
  targetId     String
  targetType   String   // user, thread, reply, comment
  action       String   // block, delete, warning
  reason       String
  createdAt    DateTime @default(now())

  @@map("moderation_actions")
}

enum status {
  PENDING
  APPROVED
  REJECTED
}

enum userRole {
  ADMIN
  USER
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ItemType {
  LOST
  FOUND
}

enum ThreadCategory {
  LOCATION
  GENERAL
  TRENDING
}

enum TrustLevel {
  NEW
  TRUSTED
  EXPERT
  MASTER
  MODERATOR
}
